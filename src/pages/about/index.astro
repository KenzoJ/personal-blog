---
import { Image } from "astro:assets";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import Link from "@components/Link.astro";
import { SITE, ABOUT, SOCIALS } from "@consts";
import headshot from "@assets/about/headshot.jpg";
---

<PageLayout title={ABOUT.TITLE} description={ABOUT.DESCRIPTION}>
  <Container>
    <div class="space-y-8 animate">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:gap-8">
        <Image
          src={headshot}
          alt={`Portrait of ${SITE.NAME}`}
          width={160}
          height={160}
          densities={[1, 2]}
          class="size-40 shrink-0 rounded-full object-cover"
        />
        <div class="space-y-4 min-w-0">
          <h5 class="font-semibold text-black dark:text-white">
            Let's Connect
          </h5>
          <article>
            <p>
              If you want to get in touch with me about something or just to say hi,
              reach out on social media or send me an email.
            </p>
          </article>
          <ul class="flex flex-wrap gap-2">
            {SOCIALS.map(SOCIAL => (
              <li class="flex gap-x-2 text-nowrap">
                <Link href={SOCIAL.HREF} external aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}>
                  {SOCIAL.NAME}
                </Link>
              </li>
            ))}
            <li class="line-clamp-1">
              <Link href={`mailto:${SITE.EMAIL}`} aria-label={`Email ${SITE.NAME}`}>
                {SITE.EMAIL}
              </Link>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </Container>
</PageLayout>
